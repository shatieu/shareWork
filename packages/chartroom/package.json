{
  "name": "chartroom",
  "version": "0.1.0",
  "description": "Local-first markdown doc indexer, id-based link resolver, and pre-commit link-repair hook (Chart Room phase 1: CLI foundation).",
  "type": "module",
  "license": "MIT",
  "bin": {
    "chartroom": "./dist/cli.js"
  },
  "exports": {
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.js"
    },
    "./link-paths": {
      "types": "./dist/link-paths.d.ts",
      "import": "./dist/link-paths.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:ui-bundle": "node scripts/copy-ui-dist.mjs",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:acceptance": "node acceptance/git-mv-resolution.mjs && node acceptance/two-repo-browse.mjs && node acceptance/editor-round-trip.mjs"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "fastify": "^5.9.0",
    "gray-matter": "^4.0.3",
    "ignore": "^6.0.2",
    "remark-directive": "^4.0.0",
    "remark-directive-rehype": "^1.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.19.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.4"
  }
}
