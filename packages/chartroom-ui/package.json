{
  "name": "chartroom-ui",
  "version": "0.1.0",
  "description": "Chart Room phase 2 viewer frontend (React + Vite). Private, build-only -- never published or npx-installed on its own; its built dist/ is copied into packages/chartroom's own dist/public by that package's build step.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "dev": "vite",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "github-slugger": "^2.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-directive-rehype": "^1.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.19.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^8.1.3",
    "vitest": "^3.0.4"
  }
}
